{
  "name": "revisor-expedientes",
  "version": "0.1.0",
  "description": "IDE para revisión de expedientes jurídicos",
  "type": "module",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev:next": "next dev --turbopack",
    "dev:electron": "node scripts/build-electron.cjs && wait-on http://localhost:3000 && electron .",
    "dev": "concurrently -k -n NEXT,ELECTRON -c cyan,yellow \"npm run dev:next\" \"npm run dev:electron\"",
    "build:next": "cross-env NEXT_OUTPUT=export next build",
    "build:electron": "node scripts/build-electron.cjs",
    "build": "npm run build:next && npm run build:electron",
    "package": "npm run build && electron-builder",
    "start": "electron .",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "mx.gob.revisor-expedientes",
    "productName": "Revisor de Expedientes",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "electron/dist/**",
      "out/**",
      "node_modules/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^4.9.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
